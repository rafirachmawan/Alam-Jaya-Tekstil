// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  POTONG
  STOKPOTONG
  KURIR
  JAHIT
  QC
  RESI
  PRINT
  GUDANG
  STOKGUDANG
  SUPERADMIN
}

enum StatusPermintaan {
  MENUNGGU_PROSES
  PROSES
  MASUK_STOK_GUDANG
  SELESAI
}

enum UkuranProduk {
  XL
  XXL
  L
  M
}

enum StatusStok {
  MASUK
  KIRIM
  PROSESKIRIM
  SELESAIKIRIM
}

model User {
  id       String   @id @default(uuid())
  name     String
  username String   @unique
  email    String   @unique
  password String
  role     Role     @default(POTONG)
  session  Session? 
  permintaanProduk PermintaanProduk[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Session {
  id           String   @id @default(uuid())
  refreshToken String
  userId       String   @unique 
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  createdAt    DateTime @default(now())
}

model KategoriProduk {
  id   String   @id @default(uuid())
  name String
  slug String   @unique
  kode String   @unique
  stokPotong StokPotong[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermintaanProduk {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  stokPotong StokPotong?
  userId     String   
  namaProduk String 
  kodeKain   String?
  ukuran     UkuranProduk
  pengecek   String?
  pemotong   String?
  jumlah     Int
  hasilPotongan  Int  @default(0)
  isUrgent   Boolean
  status     StatusPermintaan
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StokPotong {
  id  String   @id @default(uuid())
  permintaanId String @unique
  permintaan PermintaanProduk @relation(fields: [permintaanId], references: [id])
  namaProduk String
  pengecek   String?
  penjahit   String?
  kodeKain   String?
  kodePotong String?
  kategori   KategoriProduk @relation(fields: [kategoriId], references: [id])
  kategoriId String
  ukuran     UkuranProduk
  status     StatusStok?    @default(MASUK)
  admin      String?
  tanggalKirim DateTime?
  jumlah     Int
}