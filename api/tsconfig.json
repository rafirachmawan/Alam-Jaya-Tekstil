{
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "lib": [ "ESNext"],
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
