{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "rewrites": [
    { "source": "/api-docs", "destination": "/src/index" },
    { "source": "/(.*)", "destination": "/src/index" }
  ]
}
