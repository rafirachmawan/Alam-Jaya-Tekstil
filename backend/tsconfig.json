{
  "compilerOptions": {
    "jsx": "react",
    "target": "ES2023",
    "module": "esnext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}